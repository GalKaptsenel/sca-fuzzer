  <ps_section howmany="1">
    <ps name="A64.simd_dp.asisdshf.SQSHLU_asisdshf_R" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize)  = V{}(n);
var result : bits(datasize);
var sat : boolean;

for e = 0 to elements-1 do
    let opelt : bits(esize) = operand[e*:esize];
    let element : integer = if src_unsigned then UInt(opelt) else SInt(opelt);
    (result[e*:esize], sat) = <a link="func_SatQ_3" file="shared_pseudocode.xml">SatQ</a>{esize}(element &lt;&lt; shift, dst_unsigned);
    if sat then FPSR().QC = '1'; end;
end;

V{datasize}(d) = result;</pstext>
    </ps>
