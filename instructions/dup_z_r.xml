  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_unpred_d.sve_int_perm_dup_r.dup_z_r_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
var operand : bits(64);
if n == 31 then
    operand = <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}();
else
    operand = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
end;
var result : bits(VL);

for e = 0 to elements-1 do
    result[e*:esize] = operand[esize-1:0];
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
