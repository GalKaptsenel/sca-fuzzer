  <heading>MOVN</heading>
  <desc>
    <brief>
      <para>Move wide with NOT</para>
    </brief>
    <authored>
      <para>This instruction moves the inverse of an optionally-shifted 16-bit immediate
value to a register.</para>
    </authored>
  </desc>
  <alias_list howmany="1">
    <alias_list_intro>This instruction is used by the alias </alias_list_intro>
    <aliasref aliaspageid="MOV_MOVN" aliasfile="mov_movn.xml" hover="Move inverted wide immediate value" punct=".">
      <text>MOV (inverted wide immediate)</text>
      <aliaspref labels="32-bit">!(IsZero(imm16) &amp;&amp; hw != '00') &amp;&amp; !IsOnes(imm16)</aliaspref>
      <aliaspref labels="64-bit">!(IsZero(imm16) &amp;&amp; hw != '00')</aliaspref>
    </aliasref>
    <alias_list_outro>
      <text>  See </text>
      <aliastablelink/>
      <text> below for details of when the alias is preferred.</text>
    </alias_list_outro>
  </alias_list>
  <classes>
