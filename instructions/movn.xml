      <ps_section howmany="1">
        <ps name="A64.dpimm.movewide.MOVN_32_movewide" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if sf == '0' &amp;&amp; hw[1] == '1' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer = UInt(Rd);
let datasize : integer{} = 32 &lt;&lt; UInt(sf);
let imm : bits(16) = imm16;
let pos : integer{} = UInt(hw) &lt;&lt; 4;</pstext>
        </ps>
