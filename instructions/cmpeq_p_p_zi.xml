    <ps name="A64.sve.sve_cmpsimm.sve_int_scmp_vi.cmpeq_p_p_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand1 : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
var result : bits(PL);
let psize : integer{} = esize DIV 8;

for e = 0 to elements-1 do
    let op1elt : bits(esize) = operand1[e*:esize];
    let element1 : integer = if unsigned then UInt(op1elt) else SInt(op1elt);
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        var cond : boolean;
        case cmp_op of
            when Cmp_EQ =&gt; cond = element1 == imm;
            when Cmp_NE =&gt; cond = element1 != imm;
            when Cmp_GE =&gt; cond = element1 &gt;= imm;
            when Cmp_LT =&gt; cond = element1 &lt;  imm;
            when Cmp_GT =&gt; cond = element1 &gt;  imm;
            when Cmp_LE =&gt; cond = element1 &lt;= imm;
        end;
        let pbit : bit = if cond then '1' else '0';
        result[e*:psize] = ZeroExtend{psize}(pbit);
    else
        result[e*:psize] = ZeroExtend{psize}('0');
    end;
end;

PSTATE.[N,Z,C,V] = <a link="func_PredTest_4" file="shared_pseudocode.xml">PredTest</a>{PL}(mask, result, esize);
<a link="accessor_P_2" file="shared_pseudocode.xml">P</a>{PL}(d) = result;</pstext>
    </ps>
