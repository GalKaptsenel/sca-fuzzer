      <ps_section howmany="1">
        <ps name="A64.sve.sve_perm_unpred_a.sve_int_perm_dup_i.dup_z_zi_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SVE) &amp;&amp; !IsFeatureImplemented(FEAT_SME) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
if tsz == '00000' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let lsb : integer{} = LowestSetBit(tsz);
let esize : integer{} = 8 &lt;&lt; lsb;
let imm : bits(7) = imm2::tsz;
let index : integer = UInt(imm[6:(lsb+1)]);
let n : integer = UInt(Zn);
let d : integer = UInt(Zd);</pstext>
