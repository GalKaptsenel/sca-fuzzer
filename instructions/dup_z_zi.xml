  <aliastablehook anchor="aliasconditions">Alias Conditions</aliastablehook>
  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_unpred_a.sve_int_perm_dup_i.dup_z_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand1 : bits(VL) = if index &lt; elements then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
var result : bits(VL);
var element : bits(esize);

if index &gt;= elements then
    element = Zeros{esize};
else
    element = operand1[index*:esize];
end;
result = Replicate{VL}(element);

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
