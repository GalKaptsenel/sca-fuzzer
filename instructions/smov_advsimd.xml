      <ps_section howmany="1">
        <ps name="A64.simd_dp.asimdins.SMOV_asimdins_W_w" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_AdvSIMD) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if imm5 == 'xx000' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let size : integer{} = LowestSetBitNZ(imm5[2:0]);

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let esize : integer{} = 8 &lt;&lt; size;
let datasize : integer{} = 32 &lt;&lt; UInt(Q);
if datasize &lt;= esize then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let index : integer = UInt(imm5[4:size+1]);
let idxdsize : integer{} = 64 &lt;&lt; UInt(imm5[4]);</pstext>
