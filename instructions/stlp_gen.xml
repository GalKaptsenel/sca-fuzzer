      <ps_section howmany="1">
        <ps name="A64.ldst.ldiappstilp.STLP_64_ldiappstilp" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_LSCP) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let t : integer{} = UInt(Rt);
let t2 : integer{} = UInt(Rt2);
let n : integer{} = UInt(Rn);
let acquire : boolean = FALSE;
let tagchecked : boolean = n != 31;
let ispair : boolean = TRUE;</pstext>
