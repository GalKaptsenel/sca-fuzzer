  <ps_section howmany="1">
    <ps name="A64.ldst.ldiappstilp.STLP_64_ldiappstilp" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">var address : bits(64);
var data1 : bits(64);
var data2 : bits(64);
let privileged : boolean = PSTATE.EL != <a link="global_EL0" file="shared_pseudocode.xml">EL0</a>;

let accdesc : <a link="type_AccessDescriptor" file="shared_pseudocode.xml">AccessDescriptor</a> = CreateAccDescAcqRel(MemOp_STORE, tagchecked, ispair, acquire,
                                                        t, t2);

if n == 31 then
    CheckSPAlignment();
    address = <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}();
else
    address = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
end;

data1 = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(t);
data2 = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(t2);
let full_data : bits(128) = (if <a link="func_BigEndian_1" file="shared_pseudocode.xml">BigEndian</a>(accdesc.acctype) then data1::data2
                                                              else data2::data1);
<a link="accessor_Mem_3" file="shared_pseudocode.xml">Mem</a>{128}(address, accdesc) = full_data;</pstext>
    </ps>
