  <ps_section howmany="1">
    <ps name="A64.sve.sve_mem32.sve_mem_32b_prfm_vi.prfd_i_p_ai_s" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckNonStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
var base : bits(VL);

if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then
    base = <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n);
end;

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        let addr : bits(64) = ZeroExtend{64}(base[e*:esize]) + (offset &lt;&lt; scale);
        Hint_Prefetch(addr, pref_hint, level, stream);
    end;
end;</pstext>
    </ps>
