  <ps_section howmany="1">
    <ps name="A64.sve.sve_pred_gen_d.sve_int_ptrue.ptrue_p_s_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let count : integer = <a link="func_DecodePredCount_2" file="shared_pseudocode.xml">DecodePredCount</a>(pat, esize);
var result : bits(PL);
let psize : integer{} = esize DIV 8;

for e = 0 to elements-1 do
    let pbit : bit = if e &lt; count then '1' else '0';
    result[e*:psize] = ZeroExtend{psize}(pbit);
end;

if setflags then
    PSTATE.[N,Z,C,V] = <a link="func_PredTest_4" file="shared_pseudocode.xml">PredTest</a>{PL}(result, result, esize);
end;
<a link="accessor_P_2" file="shared_pseudocode.xml">P</a>{PL}(d) = result;</pstext>
    </ps>
