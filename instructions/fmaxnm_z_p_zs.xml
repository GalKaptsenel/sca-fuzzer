      <ps_section howmany="1">
        <ps name="A64.sve.sve_fp_pred.sve_fp_2op_i_p_zds.fmaxnm_z_p_zs_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SVE) &amp;&amp; !IsFeatureImplemented(FEAT_SME) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
if size == '00' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8 &lt;&lt; UInt(size);
let g : integer = UInt(Pg);
let dn : integer = UInt(Zdn);
let imm : bits(esize) = if i1 == '0' then Zeros{esize} else <a link="func_FPOne_2" file="shared_pseudocode.xml">FPOne</a>{esize}('0');</pstext>
        </ps>
