  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_fcvt2.sve_fp_fcvt2.bfcvtnt_z_p_z_s2bf" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV 32;
let mask : bits(PL) = P{}(g);
let operand : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, 32) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
var result : bits(VL) = Z{}(d);

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, 32) then
        let element : bits(32) = operand[e*:32];
        result[(2*e+1)*:16] = <a link="func_FPConvertBF_2" file="shared_pseudocode.xml">FPConvertBF</a>(element, FPCR());
    elsif !merging then
        result[(2*e+1)*:16] = Zeros{16};

    end;
end;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
