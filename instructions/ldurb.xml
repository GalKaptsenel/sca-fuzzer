  <ps_section howmany="1">
    <ps name="A64.ldst.ldst_unscaled.LDURB_32_ldst_unscaled" sections="1" secttype="Shared Decode">
      <pstext mayhavelinks="1" section="Postdecode" rep_section="postdecode">let n : integer = UInt(Rn);
let t : integer = UInt(Rt);
let datasize : integer{} = 8;
let nontemporal : boolean = FALSE;
let tagchecked : boolean = n != 31;</pstext>
    </ps>
  </ps_section>
  <ps_section howmany="1">
    <ps name="A64.ldst.ldst_unscaled.LDURB_32_ldst_unscaled" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">var address : bits(64);

let privileged : boolean = PSTATE.EL != <a link="global_EL0" file="shared_pseudocode.xml">EL0</a>;
let accdesc : <a link="type_AccessDescriptor" file="shared_pseudocode.xml">AccessDescriptor</a> = CreateAccDescGPR(MemOp_LOAD, nontemporal, privileged,
                                                  tagchecked, t);

if n == 31 then
    CheckSPAlignment();
    address = <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}();
else
    address = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
end;

address = <a link="func_AddressAdd_3" file="shared_pseudocode.xml">AddressAdd</a>(address, offset, accdesc);

let data : bits(datasize) = <a link="accessor_Mem_3" file="shared_pseudocode.xml">Mem</a>{datasize}(address, accdesc);
<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{32}(t) = ZeroExtend{32}(data);</pstext>
    </ps>
  </ps_section>
