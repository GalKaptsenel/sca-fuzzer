  <ps_section howmany="1">
    <ps name="A64.simd_dp.floatdp3.FMADD_H_floatdp3" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();

let addend : bits(esize)   = V{esize}(a);
let operand1 : bits(esize) = V{esize}(n);
let operand2 : bits(esize) = V{}(m);

var result : bits(128) = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then V{128}(a) else Zeros{128};

result[0+:esize] = <a link="func_FPMulAdd_5" file="shared_pseudocode.xml">FPMulAdd</a>{esize}(addend, operand1, operand2, FPCR());
V{128}(d) = result;</pstext>
    </ps>
