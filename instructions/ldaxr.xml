      <ps_section howmany="1">
        <ps name="A64.ldst.ldstexclr.LDAXR_LR32_ldstexclr" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">let t : integer{} = UInt(Rt);
let n : integer{} = UInt(Rn);

let elsize : integer{} = 8 &lt;&lt; UInt(size);
let regsize : integer{} = if elsize == 64 then 64 else 32;
let acqrel : boolean = t != 31;
let tagchecked : boolean = n != 31;
</pstext>
