  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdsame2.FMMLA_asimd_FP16FP16" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(128) = V{}(n);
let operand2 : bits(128) = V{}(m);
let operand3 : bits(128) = V{}(d);

var result : bits(128);

for s = 0 to 1 do
    let op1 : bits(64) = operand1[s*:64];
    let op2 : bits(64) = operand2[s*:64];
    let acc : bits(64) = operand3[s*:64];
    result[s*:64] = FPMatMulAdd{64}(acc, op1, op2, 16, FPCR());
end;

V{128}(d) = result;</pstext>
    </ps>
