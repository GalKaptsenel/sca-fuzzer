    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
let esize : integer{} = 8 &lt;&lt; UInt(size);
let d : integer = UInt(Zd);
let imm1 : integer = SInt(imm5);
let imm2 : integer = SInt(imm5b);</pstext>
