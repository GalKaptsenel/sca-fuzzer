      <ps_section howmany="1">
        <ps name="A64.ldst.memop.LDSMIN_32_memop" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_LSE) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let s : integer{} = UInt(Rs);
let t : integer{} = UInt(Rt);
let n : integer{} = UInt(Rn);

let datasize : integer{} = 8 &lt;&lt; UInt(size);
let regsize : integer{} = if datasize == 64 then 64 else 32;

let acquire : boolean = A == '1' &amp;&amp; Rt != '11111';
let release : boolean = R == '1';
let tagchecked : boolean = n != 31;</pstext>
        </ps>
