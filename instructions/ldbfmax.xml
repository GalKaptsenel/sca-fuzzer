      <ps_section howmany="1">
        <ps name="A64.ldst.memop.LDBFMAX_16" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_LSFE) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let t : integer = UInt(Rt);
let n : integer = UInt(Rn);
let s : integer = UInt(Rs);

let datasize : integer{} = 16;
let acquire : boolean = A == '1';
let release : boolean = R == '1';
let tagchecked : boolean = n != 31;</pstext>
        </ps>
