  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_unpred_c.sve_int_perm_tbl.tbl_z_zz_1" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let indexes : bits(VL) = Z{}(m);
var result : bits(VL);
let table_size : integer{} = if double_table then VL*2 else VL;
let table_elems : integer = table_size DIV esize;
var table : bits(table_size);

if double_table then
    let top : bits(VL) = Z{}((n + 1) MOD 32);
    let bottom : bits(VL) = Z{}(n);
    table = (top::bottom)[table_size-1:0];
else
    table = <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{table_size}(n);
end;

for e = 0 to elements-1 do
    let idx : integer = UInt(indexes[e*:esize]);
    result[e*:esize] = if idx &lt; table_elems then table[idx*:esize] else Zeros{esize};
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
