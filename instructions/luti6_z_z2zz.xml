    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
if <a link="func_MaxImplementedAnyVL_0" file="shared_pseudocode.xml">MaxImplementedAnyVL</a>() &lt; 512 then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let isize : integer{} = 6;
let esize : integer{} = 16;
let m : integer = UInt(Zm);
let n : integer = UInt(Zn);
let d : integer = UInt(Zd);
let part : integer = UInt(i1);</pstext>
