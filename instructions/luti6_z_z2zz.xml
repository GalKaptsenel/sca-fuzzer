  <ps_section howmany="1">
    <ps name="A64.sve.sve_intx_histseg_lut.sve_intx_lut6_16.luti6_z_zzz_16" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
if VL &lt; 512 then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let elements : integer = VL DIV esize;
let ibase : integer = elements * part;
let indexes : bits(VL) = Z{}(m); // Only bottom 3/4 used
let table : bits(1024)  = <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}((n+1) MOD 32)[511:0] :: <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n+0)[511:0];
var result : bits(VL);

for e = 0 to elements-1 do
    let index : integer = UInt(indexes[(ibase + e)*:isize]);
    let res : bits(esize) = table[index*:esize];
    result[e*:esize] = res;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
