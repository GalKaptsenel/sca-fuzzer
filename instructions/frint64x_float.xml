      <ps_section howmany="1">
        <ps name="A64.simd_dp.floatdp1.FRINT64X_S_floatdp1" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FRINTTS) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if ftype IN {'1x'} then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let esize : integer{} = 32 &lt;&lt; UInt(ftype[0]);
let intsize : integer{} = 64;
</pstext>
