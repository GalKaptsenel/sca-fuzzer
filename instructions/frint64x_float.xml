  <ps_section howmany="1">
    <ps name="A64.simd_dp.floatdp1.FRINT64X_S_floatdp1" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();

let operand : bits(esize) = V{}(n);
let rounding : <a link="type_FPRounding" file="shared_pseudocode.xml">FPRounding</a> = <a link="func_FPRoundingMode_1" file="shared_pseudocode.xml">FPRoundingMode</a>(FPCR());
var result : bits(128) = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then V{128}(d) else Zeros{128};

result[0+:esize] = <a link="func_FPRoundIntN_5" file="shared_pseudocode.xml">FPRoundIntN</a>{esize}(operand, FPCR(), rounding, intsize);

V{128}(d) = result;</pstext>
    </ps>
