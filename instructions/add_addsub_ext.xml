      <ps_section howmany="1">
        <ps name="A64.dpreg.addsub_ext.ADD_32_addsub_ext" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if imm3 IN {'101', '110', '111'} then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let m : integer{} = UInt(Rm);
let shift : integer{} = UInt(imm3) as integer{0..4};
let datasize : integer{} = 32 &lt;&lt; UInt(sf);
let extend_type : <a link="type_ExtendType" file="shared_pseudocode.xml">ExtendType</a> = <a link="func_DecodeRegExtend_1" file="shared_pseudocode.xml">DecodeRegExtend</a>(option);</pstext>
