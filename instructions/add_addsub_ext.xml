  <ps_section howmany="1">
    <ps name="A64.dpreg.addsub_ext.ADD_32_addsub_ext" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">let operand1 : bits(datasize) = if n == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{datasize}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{datasize}(n);
let operand2 : bits(datasize) = ExtendReg{}(m, extend_type, shift);
var result : bits(datasize);

(result, -) = <a link="func_AddWithCarry_4" file="shared_pseudocode.xml">AddWithCarry</a>{datasize}(operand1, operand2, '0');

if d == 31 then
    <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() = ZeroExtend{64}(result);
else
    <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{datasize}(d) = result;
end;</pstext>
    </ps>
  </ps_section>
