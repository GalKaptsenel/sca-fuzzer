  <heading>UZP (four registers)</heading>
  <desc>
    <brief>
      <para>Concatenate elements from four vectors</para>
    </brief>
    <authored>
      <para>This instruction concatenates every fourth element from each of the four source vectors
and places them in the corresponding elements of the four destination vectors.</para>
      <para>This instruction is unpredicated.</para>
    </authored>
    <predicated>False</predicated>
    <uses_dit condition="FEAT_SVE2 is implemented or FEAT_SME is implemented">True</uses_dit>
    <sm_policy>SM_1_only</sm_policy>
  </desc>
  <operationalnotes>
    <operationalnote>
      <operationalnote_content>
        <para>This instruction is a data-independent-time instruction as described in <xref linkend="ARMARM_BEICCDDAB3">About PSTATE.DIT</xref>.</para>
      </operationalnote_content>
    </operationalnote>
  </operationalnotes>
