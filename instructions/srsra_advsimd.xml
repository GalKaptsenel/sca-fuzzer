      <ps_section howmany="1">
        <ps name="A64.simd_dp.asisdshf.SRSRA_asisdshf_R" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_AdvSIMD) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if immh[3] != '1' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let esize : integer{} = 8 &lt;&lt; 3;
let datasize : integer{} = esize;
let elements : integer = 1;

let shift : integer = (esize * 2) - UInt(immh::immb);
let unsigned : boolean = FALSE;
let round : boolean = TRUE;</pstext>
