  <ps_section howmany="1">
    <ps name="A64.simd_dp.asisdshf.SRSRA_asisdshf_R" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize)  = V{}(n);
let operand2 : bits(datasize) = V{}(d);
var result : bits(datasize);
var element : integer;

for e = 0 to elements-1 do
    let opelt : bits(esize) = operand[e*:esize];
    if unsigned then
        element = <a link="func_RShr_3" file="shared_pseudocode.xml">RShr</a>(UInt(opelt), shift, round);
    else
        element = <a link="func_RShr_3" file="shared_pseudocode.xml">RShr</a>(SInt(opelt), shift, round);
    end;
    result[e*:esize] = operand2[e*:esize] + element[esize-1:0];
end;

V{datasize}(d) = result;</pstext>
    </ps>
  </ps_section>
