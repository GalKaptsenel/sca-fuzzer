  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_sve_3.mortlach_multi4_qrshr.sqrshrun_z_mz4_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV (4 * esize);
var result : bits(VL);

for e = 0 to elements-1 do
    for i = 0 to 3 do
        let operand : bits(VL) = Z{}(n+i);
        let element : bits(4 * esize) = operand[e*:(4 * esize)];
        let res : integer = (SInt(element) + (1 &lt;&lt; (shift-1))) &gt;&gt; shift;
        result[(4*e + i)*:esize] = <a link="func_UnsignedSat_2" file="shared_pseudocode.xml">UnsignedSat</a>{esize}(res);
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
