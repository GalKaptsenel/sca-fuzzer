      <ps_section howmany="1">
        <ps name="A64.sme.mortlach_multi_sve_3.mortlach_multi4_qrshr.sqrshrun_z_mz4_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SME2) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if tsize == '00' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8 &lt;&lt; HighestSetBitNZ(tsize);
let n : integer = UInt(Zn::'00');
let d : integer = UInt(Zd);
let shift : integer = (8 * esize) - UInt(tsize::imm5);</pstext>
