  <ps_section howmany="1">
    <ps name="A64.simd_dp.asisdshf.FCVTZS_asisdshf_C" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize)  = V{}(n);

let merge : boolean = elements == 1 &amp;&amp; <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR());
var result : bits(128) = if merge then V{128}(d) else Zeros{128};
var element : bits(esize);

for e = 0 to elements-1 do
    element = operand[e*:esize];
    result[e*:esize] = <a link="func_FPToFixed_7" file="shared_pseudocode.xml">FPToFixed</a>{esize, esize}(element, fracbits, unsigned, FPCR(), rounding);
end;

V{128}(d) = result;</pstext>
    </ps>
