          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_AdvSIMD) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if immh IN {'000x'} || (immh IN {'001x'} &amp;&amp; !IsFeatureImplemented(FEAT_FP16)) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let esize : integer{} = if immh IN {'1xxx'} then 64 else if immh IN {'01xx'} then 32 else 16;
let datasize : integer{} = esize;
let elements : integer = 1;

let fracbits : integer = (esize * 2) - UInt(immh::immb);
let unsigned : boolean = FALSE;
let rounding : <a link="type_FPRounding" file="shared_pseudocode.xml">FPRounding</a> = <a link="enum_FPRounding_ZERO" file="shared_pseudocode.xml">FPRounding_ZERO</a>;</pstext>
