  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_sve_4.mortlach_multi2_wide_fp8_cvrt.bf1cvt_mz2_z8_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckFPMREnabled();
CheckStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV 8;
let operand : bits(VL) = Z{}(n);
var result : bits(2*VL);

for e = 0 to elements-1 do
    let element : bits(8) = operand[e*:8];
    result[e*:16] = <a link="func_FP8ConvertBF_4" file="shared_pseudocode.xml">FP8ConvertBF</a>(element, issrc2, FPCR(), FPMR());
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d+0) = result[VL-1:0];
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d+1) = result[2*VL-1:VL];</pstext>
    </ps>
