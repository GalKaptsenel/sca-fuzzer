  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdmisc.SHLL_asimdmisc_S" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize) = Vpart{}(n, part);
var result : bits(2*datasize);
var element : integer;

for e = 0 to elements-1 do
    element = SInt(operand[e*:esize]) &lt;&lt; shift;
    result[e*:(2*esize)] = element[2*esize-1:0];
end;

V{2*datasize}(d) = result;</pstext>
    </ps>
