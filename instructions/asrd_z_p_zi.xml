  <ps_section howmany="1">
    <ps name="A64.sve.sve_int_pred_shift.sve_int_bin_pred_shift_0.asrd_z_p_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand1 : bits(VL) = Z{}(dn);
var result : bits(VL);

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        var element1 : integer = SInt(operand1[e*:esize]);
        if element1 &lt; 0 then
            element1 = element1 + ((1 &lt;&lt; shift) - 1);
        end;
        result[e*:esize] = (element1 &gt;&gt; shift)[esize-1:0];
    else
        result[e*:esize] = operand1[e*:esize];
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dn) = result;</pstext>
    </ps>
