  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_zt_expand_ctg.mortlach_expand_4dst3src_ctg.luti6_mz4_ztmz3_1" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
CheckSMEZT0Enabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let indexes : bits(3*VL) = <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n+2) :: <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n+1) :: <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n+0);
var dst : integer = d;
let table : bits(512) = ZT0{}();

for r = 0 to 3 do
    let base : integer = r * elements;
    var result : bits(VL);
    for e = 0 to elements-1 do
        let index : integer = UInt(indexes[(base+e)*:isize]);
        result[e*:esize] = table[index*:esize];
    end;
    <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dst) = result;
    dst = dst + dstride;
end;</pstext>
    </ps>
