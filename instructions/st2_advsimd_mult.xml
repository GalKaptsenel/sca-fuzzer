  <ps_section howmany="1">
    <ps name="A64.ldst.asisdlse.ST2_asisdlse_R2" sections="1" secttype="Shared Decode">
      <pstext mayhavelinks="1" section="Postdecode" rep_section="postdecode">let datasize : integer{} = 64 &lt;&lt; UInt(Q);
let esize : integer{} = 8 &lt;&lt; UInt(size);
let elements : integer = datasize DIV esize;

let rpt : integer = 1;
let selem : integer = 2;

// .1D format only permitted with LD1 &amp; ST1
if size::Q == '110' &amp;&amp; selem != 1 then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;</pstext>
    </ps>
  </ps_section>
  <ps_section howmany="1">
    <ps name="A64.ldst.asisdlse.ST2_asisdlse_R2" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

var address : bits(64);
var eaddr : bits(64);
var offs : bits(64);
var rval : bits(datasize);
var tt : integer;
let ebytes : integer{} = esize DIV 8;

let privileged : boolean = PSTATE.EL != <a link="global_EL0" file="shared_pseudocode.xml">EL0</a>;
let accdesc : <a link="type_AccessDescriptor" file="shared_pseudocode.xml">AccessDescriptor</a> = CreateAccDescASIMD(MemOp_STORE, nontemporal, tagchecked,
                                                       privileged);
if n == 31 then
    CheckSPAlignment();
    address = <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}();
else
    address = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
end;

offs = Zeros{64};
for r = 0 to rpt-1 do
    for e = 0 to elements-1 do
        tt = (t + r) MOD 32;
        for s = 0 to selem-1 do
            rval = V{datasize}(tt);
            eaddr = <a link="func_AddressIncrement_3" file="shared_pseudocode.xml">AddressIncrement</a>(address, offs, accdesc);
            <a link="accessor_Mem_3" file="shared_pseudocode.xml">Mem</a>{esize}(eaddr, accdesc) = rval[e*:esize];
            offs = offs + ebytes;
            tt = (tt + 1) MOD 32;
        end;
    end;
end;
if wback then
    if m != 31 then
        offs = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(m);
    end;
    address = <a link="func_AddressAdd_3" file="shared_pseudocode.xml">AddressAdd</a>(address, offs, accdesc);
    if n == 31 then
        <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() = address;
    else
        <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n) = address;
    end;
end;</pstext>
    </ps>
