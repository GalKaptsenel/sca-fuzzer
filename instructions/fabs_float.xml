      <ps_section howmany="1">
        <ps name="A64.simd_dp.floatdp1.FABS_H_floatdp1" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FP) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if ftype == '10' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if ftype == '11' &amp;&amp; !IsFeatureImplemented(FEAT_FP16) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);

let esize : integer{} = 8 &lt;&lt; UInt(ftype XOR '10');</pstext>
