  <ps_section howmany="1">
    <ps name="A64.simd_dp.floatdp1.FABS_H_floatdp1" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();

let operand : bits(esize) = V{}(n);
var result : bits(128) = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then V{128}(d) else Zeros{128};

result[0+:esize] = <a link="func_FPAbs_3" file="shared_pseudocode.xml">FPAbs</a>{esize}(operand, FPCR());

V{128}(d) = result;</pstext>
    </ps>
