  <ps_section howmany="1">
    <ps name="A64.simd_dp.cryptosha512_2.SHA512SU0_VV2_cryptosha512_2" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

var sig0 : bits(64);
var Vtmp : bits(128);
let x : bits(128) = V{}(n);
let w : bits(128) = V{}(d);
sig0 = ROR(w[127:64], 1) XOR ROR(w[127:64], 8) XOR ('0000000'::w[127:71]);
Vtmp[63:0] = w[63:0] + sig0;
sig0 = ROR(x[63:0], 1) XOR ROR(x[63:0], 8) XOR ('0000000'::x[63:7]);
Vtmp[127:64] = w[127:64] + sig0;
V{128}(d) = Vtmp;</pstext>
    </ps>
