      <ps_section howmany="1">
        <ps name="A64.ldst.ldstord.STLLRH_SL32_ldstord" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_LOR) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let t : integer{} = UInt(Rt);
let n : integer{} = UInt(Rn);
let acquire : boolean = FALSE;
let tagchecked : boolean = n != 31;</pstext>
