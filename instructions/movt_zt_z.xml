  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_mov_zt.mortlach_move_to_zt.movt_zt_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
CheckSMEZT0Enabled();
let VL : integer{} = CurrentVL();
let tsize : integer{} = (if VL &lt;= 512 then VL else 512) as integer{128, 256, 512};
let offset : integer = imm MOD (512 DIV tsize);
var result : bits(512) = if imm == 0 then Zeros{512} else <a link="accessor_ZT0_1" file="shared_pseudocode.xml">ZT0</a>{512}();

result[offset*:tsize] = <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(t)[tsize-1:0];
<a link="accessor_ZT0_1" file="shared_pseudocode.xml">ZT0</a>{512}() = result;</pstext>
    </ps>
