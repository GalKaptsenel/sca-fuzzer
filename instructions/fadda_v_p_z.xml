  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_slowreduce.sve_fp_2op_p_vd.fadda_v_p_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckNonStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand1 : bits(esize) = V{}(dn);
let operand2 : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(m) else Zeros{VL};
var result : bits(esize) = operand1;

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        let element : bits(esize) = operand2[e*:esize];
        result = <a link="func_FPAdd_4" file="shared_pseudocode.xml">FPAdd</a>{esize}(result, element, FPCR());
    end;
end;

V{esize}(dn) = result;</pstext>
