    <ps name="A64.control.exception.HVC_EX_exception" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">if PSTATE.EL == <a link="global_EL0" file="shared_pseudocode.xml">EL0</a> then Undefined(); end;
if PSTATE.EL == <a link="global_EL1" file="shared_pseudocode.xml">EL1</a> &amp;&amp; !<a link="func_EL2Enabled_0" file="shared_pseudocode.xml">EL2Enabled</a>() then Undefined(); end;
if !<a link="func_HaveEL_1" file="shared_pseudocode.xml">HaveEL</a>(<a link="global_EL3" file="shared_pseudocode.xml">EL3</a>) &amp;&amp; HCR_EL2().HCD == '1' then Undefined(); end;
if <a link="func_HaveEL_1" file="shared_pseudocode.xml">HaveEL</a>(<a link="global_EL3" file="shared_pseudocode.xml">EL3</a>) &amp;&amp; SCR_EL3().HCE == '0' then Undefined(); end;

AArch64_CallHypervisor(imm);</pstext>
