  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_ins.mortlach_insert_pred.mova_za_p_rz_b" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEAndZAEnabled();
let  VL : integer{} = CurrentVL();
let  PL : integer{} = VL DIV 8;
let dim : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand : bits(VL) = Z{}(n);
let index : bits(32) = X{}(s);
let slice : integer = (UInt(index) + offset) MOD dim;
var result : bits(VL) = ZAslice{}(d, esize, vertical, slice);

for e = 0 to dim-1 do
    let element : bits(esize) = operand[e*:esize];
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        result[e*:esize] = element;
    end;
end;

ZAslice{VL}(d, esize, vertical, slice) = result;</pstext>
    </ps>
