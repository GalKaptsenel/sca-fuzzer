  <ps_section howmany="1">
    <ps name="A64.sve.sve_int_pred_red.sve_int_reduce_1q.uminqv_z_p_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let segments : integer = VL DIV 128;
let elempersegment : integer = 128 DIV esize;
let mask : bits(PL) = P{}(g);
let operand : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
var result : bits(128) = Zeros{};
var stmp : bits(128) = Zeros{};

var dtmp : integer;

for e = 0 to elempersegment-1 do
    dtmp = if unsigned then (2^esize - 1) else (2^(esize-1) - 1);
    for s = 0 to segments-1 do
        if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, s * elempersegment + e, esize) then
            stmp = operand[s*:128];
            dtmp = Min(dtmp, UInt(stmp[e*:esize]));
        end;
    end;
    result[e*:esize] = dtmp[esize-1:0];
end;

V{128}(d) = result;</pstext>
    </ps>
