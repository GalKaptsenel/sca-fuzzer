  <ps_section howmany="1">
    <ps name="A64.sve.sve_pred_count_a.sve_int_pcount_pn.cntp_r_pn_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">if IsFeatureImplemented(FEAT_SVE2p1) then CheckSVEEnabled(); else CheckStreamingSVEEnabled(); end;
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let pred : bits(PL) = P{}(n);
let mask : bits(PL*4) = CounterToPredicate{}(pred[15:0]);
var sum : bits(64) = Zeros{};
let maxelements : integer = elements * width;

for e = 0 to maxelements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL*4}(mask, e, esize) then
        sum = sum + 1;
    end;
end;
<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = sum;</pstext>
    </ps>
