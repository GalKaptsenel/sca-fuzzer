  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdsame2.FMLALLBB_asimdsame2_G" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckFPMREnabled(); AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(128) = V{}(n);
let operand2 : bits(128) = V{}(m);
let operand3 : bits(128) = V{}(d);
var result : bits(128);

for e = 0 to elements-1 do
    let element1 : bits(8)  = operand1[(4 * e + sel)*:8];
    let element2 : bits(8)  = operand2[(4 * e + sel)*:8];
    let element3 : bits(32) = operand3[e*:32];
    result[e*:32] = <a link="func_FP8MulAddFP_6" file="shared_pseudocode.xml">FP8MulAddFP</a>{32}(element3, element1, element2, FPCR(), FPMR());
end;

V{128}(d) = result;</pstext>
    </ps>
