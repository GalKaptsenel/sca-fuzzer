  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_array_1a.mortlach_multi1_zz_za_mla_long_long_sm.usmlall_za_zzv_s" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEAndZAEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let vectors : integer = VL DIV 8;
let vstride : integer = vectors DIV nreg;
let vbase : bits(32) = X{}(v);
var vec : integer = (UInt(vbase) + offset) MOD vstride;
var result : bits(VL);
vec = vec - (vec MOD 4);

for r = 0 to nreg-1 do
    let operand1 : bits(VL) = Z{}((n+r) MOD 32);
    let operand2 : bits(VL) = Z{}(m);
    for i = 0 to 3 do
        let operand3 : bits(VL) = ZAvector{}(vec + i);
        for e = 0 to elements-1 do
            let element1 : integer = UInt(operand1[(4 * e + i)*:(esize DIV 4)]);
            let element2 : integer = SInt(operand2[(4 * e + i)*:(esize DIV 4)]);
            let product : bits(esize) = (element1 * element2)[esize-1:0];
            result[e*:esize] = operand3[e*:esize] + product;
        end;
        <a link="accessor_ZAvector_2" file="shared_pseudocode.xml">ZAvector</a>{VL}(vec + i) = result;
    end;
    vec = vec + vstride;
end;</pstext>
    </ps>
