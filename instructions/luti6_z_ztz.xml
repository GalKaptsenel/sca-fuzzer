      <ps_section howmany="1">
        <ps name="A64.sme.mortlach_zt_expand_ctg.mortlach_expand_1dst.luti6_z_ztz_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SME2p3) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8;
let isize : integer{} = 6;
