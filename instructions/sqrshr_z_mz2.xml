      <ps_section howmany="1">
        <ps name="A64.sme.mortlach_multi_sve_3.mortlach_multi2_qrshr.sqrshr_z_mz2_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SME2) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 16;
let n : integer = UInt(Zn::'0');
let d : integer = UInt(Zd);
let shift : integer = esize - UInt(imm4);</pstext>
