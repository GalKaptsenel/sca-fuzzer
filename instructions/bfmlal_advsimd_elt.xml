          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_BF16) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let n : integer = UInt(Rn);
let m : integer = UInt('0'::Rm);
let d : integer = UInt(Rd);
let index : integer = UInt(H::L::M);

let elements : integer = 128 DIV 32;
let sel : integer = UInt(Q);</pstext>
