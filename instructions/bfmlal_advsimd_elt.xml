  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdelem.BFMLAL_asimdelem_F" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
var result : bits(128);
let operand1 : bits(128) = V{}(n);
let operand2 : bits(128) = V{}(m);
let operand3 : bits(128) = V{}(d);
let element2 : bits(16)  = operand2[index*:16];

for e = 0 to elements-1 do
    let element1 : bits(16)   = operand1[(2 * e + sel)*:16];
    let addend : bits(32)     = operand3[e*:32];
    result[e*:32] = <a link="func_BFMulAddH_4" file="shared_pseudocode.xml">BFMulAddH</a>(addend, element1, element2, FPCR());
end;

V{128}(d) = result;</pstext>
    </ps>
