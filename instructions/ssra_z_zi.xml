  <ps_section howmany="1">
    <ps name="A64.sve.sve_intx_acc.sve_intx_sra.ssra_z_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand1 : bits(VL) = Z{}(n);
let operand2 : bits(VL) = Z{}(da);
var result : bits(VL);

for e = 0 to elements-1 do
    let element : integer = SInt(operand1[e*:esize]) &gt;&gt; shift;
    result[e*:esize] = operand2[e*:esize] + element[esize-1:0];
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(da) = result;</pstext>
    </ps>
