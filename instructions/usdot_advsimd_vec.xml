      <ps_section howmany="1">
        <ps name="A64.simd_dp.asimdsame2.USDOT_asimdsame2_D" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_I8MM) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let m : integer{} = UInt(Rm);
let datasize : integer{} = 64 &lt;&lt; UInt(Q);
let elements : integer = datasize DIV 32;</pstext>
