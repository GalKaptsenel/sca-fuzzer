  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdsame2.USDOT_asimdsame2_D" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(datasize) = V{}(n);
let operand2 : bits(datasize) = V{}(m);
let operand3 : bits(datasize) = V{}(d);
var result : bits(datasize);

for e = 0 to elements-1 do
    var res : bits(32) = operand3[e*:32];
    for b = 0 to 3 do
        let element1 : integer = UInt(operand1[(4 * e + b)*:8]);
        let element2 : integer = SInt(operand2[(4 * e + b)*:8]);
        res = res + element1 * element2;
    end;
    result[e*:32] = res;
end;

V{datasize}(d) = result;</pstext>
    </ps>
