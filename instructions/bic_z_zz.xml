    <ps name="A64.sve.sve_int_unpred_logical.sve_int_bin_cons_log.bic_z_zz_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let operand1 : bits(VL) = Z{}(n);
let operand2 : bits(VL) = Z{}(m);

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = operand1 AND (NOT operand2);</pstext>
