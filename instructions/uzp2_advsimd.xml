  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdperm.UZP2_asimdperm_only" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operandl : bits(datasize) = V{}(n);
let operandh : bits(datasize) = V{}(m);
var result : bits(datasize);

let zipped : bits(datasize*2) = operandh::operandl;
for e = 0 to elements-1 do
    result[e*:esize] = zipped[(2*e+part)*:esize];
end;

V{datasize}(d) = result;</pstext>
    </ps>
