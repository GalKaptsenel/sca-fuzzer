  <ps_section howmany="1">
    <ps name="A64.simd_dp.crypto4.BCAX_VVV16_crypto4" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

let operand1 : bits(128) = V{}(m);
let operand2 : bits(128) = V{}(n);
let operand3 : bits(128) = V{}(a);

V{128}(d) = operand2 XOR (operand1 AND NOT(operand3));</pstext>
    </ps>
