  <ps_section howmany="1">
    <ps name="A64.sve.sve_wideimm_unpred.sve_int_arith_imm0.sqadd_z_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand1 : bits(VL) = Z{}(dn);
var result : bits(VL);

for e = 0 to elements-1 do
    let op1elt : bits(esize) = operand1[e*:esize];
    let element1 : integer = if unsigned then UInt(op1elt) else SInt(op1elt);
    (result[e*:esize], -) = <a link="func_SatQ_3" file="shared_pseudocode.xml">SatQ</a>{esize}(element1 + imm, unsigned);

end;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dn) = result;</pstext>
    </ps>
