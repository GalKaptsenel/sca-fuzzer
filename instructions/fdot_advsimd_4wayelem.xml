      <ps_section howmany="1">
        <ps name="A64.simd_dp.asimdelem.FDOT_asimdelem_D" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FP8DOT4) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
let n : integer = UInt(Rn);
let d : integer = UInt(Rd);
let m : integer = UInt(M::Rm);
let i : integer = UInt(H::L);

let datasize : integer{} = if Q == '1' then 128 else 64;
let esize : integer{} = 32;
let elements : integer = datasize DIV esize;</pstext>
