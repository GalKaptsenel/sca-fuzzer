  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdelem.FDOT_asimdelem_D" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckFPMREnabled(); AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(datasize) = V{}(n);
let operand2 : bits(128) = V{}(m);
let operand3 : bits(datasize) = V{}(d);
var result : bits(datasize);

for e = 0 to elements-1 do
    let op1 : bits(esize) = operand1[e*:esize];
    let op2 : bits(esize) = operand2[i*:esize];
    let sum : bits(esize) = operand3[e*:esize];

    result[e*:esize] = FP8DotAddFP{esize, esize}(sum, op1, op2, FPCR(), FPMR());
end;

V{datasize}(d) = result;</pstext>
    </ps>
