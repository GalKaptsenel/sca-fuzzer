      <ps_section howmany="1">
        <ps name="A64.sve.sve_alloca.sve_int_arith_svl.addspl_r_ri_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SME) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let n : integer = UInt(Rn);
let d : integer = UInt(Rd);
let imm : integer = SInt(imm6);</pstext>
