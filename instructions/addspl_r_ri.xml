  <ps_section howmany="1">
    <ps name="A64.sve.sve_alloca.sve_int_arith_svl.addspl_r_ri_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSMEEnabled();
let SVL : integer = CurrentSVL();
let len : integer = imm * (SVL DIV 64);
let operand1 : bits(64) = if n == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
let result : bits(64) = operand1 + len;

if d == 31 then
    <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() = result;
else
    <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = result;
end;</pstext>
    </ps>
