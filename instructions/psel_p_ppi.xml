  <ps_section howmany="1">
    <ps name="A64.sve.sve_pred_dup.sve_int_pred_dup.psel_p_ppi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let operand1 : bits(PL) = P{}(n);
let operand2 : bits(PL) = P{}(m);
let idx : bits(32) = X{}(v);
let element : integer = (UInt(idx) + imm) MOD elements;
var result : bits(PL);

if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(operand2, element, esize) then
    result = operand1;
else
    result = Zeros{PL};
end;

<a link="accessor_P_2" file="shared_pseudocode.xml">P</a>{PL}(d) = result;</pstext>
    </ps>
