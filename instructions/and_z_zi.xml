  <ps_section howmany="1">
    <ps name="A64.sve.sve_maskimm.sve_int_log_imm.and_z_zi_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV 64;
let operand : bits(VL) = Z{}(dn);
var result : bits(VL);

for e = 0 to elements-1 do
    let element1 : bits(64) = operand[e*:64];
    result[e*:64] = element1 AND imm;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dn) = result;</pstext>
    </ps>
