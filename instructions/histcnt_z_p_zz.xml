      <ps_section howmany="1">
        <ps name="A64.sve.sve_intx_histcnt.sve_intx_histcnt.histcnt_z_p_zz_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SVE2) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if size IN {'0x'} then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8 &lt;&lt; UInt(size);
let g : integer = UInt(Pg);
let d : integer = UInt(Zd);
let n : integer = UInt(Zn);
let m : integer = UInt(Zm);</pstext>
