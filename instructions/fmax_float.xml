  <ps_section howmany="1">
    <ps name="A64.simd_dp.floatdp2.FMAX_H_floatdp2" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();
let operand1 : bits(esize) = V{}(n);
let operand2 : bits(esize) = V{}(m);

var result : bits(128) = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then V{128}(n) else Zeros{128};

result[0+:esize] = <a link="func_FPMax_4" file="shared_pseudocode.xml">FPMax</a>{esize}(operand1, operand2, FPCR());

V{128}(d) = result;</pstext>
