  <ps_section howmany="1">
    <ps name="A64.ldst.memop.LD64B_64L_memop" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckLDST64BEnabled();

var data : bits(512);
var address : bits(64);
var value : bits(64);

let accdesc : <a link="type_AccessDescriptor" file="shared_pseudocode.xml">AccessDescriptor</a> = CreateAccDescLS64(MemOp_LOAD, withstatus, tagchecked);

if n == 31 then
    CheckSPAlignment();
    address = <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}();
else
    address = <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
end;
data = <a link="func_MemLoad64B_2" file="shared_pseudocode.xml">MemLoad64B</a>(address, accdesc);

for i = 0 to 7 do
    value = data[63+64*i : 64*i];
    if <a link="func_BigEndian_1" file="shared_pseudocode.xml">BigEndian</a>(accdesc.acctype) then value = <a link="func_BigEndianReverse_2" file="shared_pseudocode.xml">BigEndianReverse</a>{64}(value); end;
    <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(t+i) = value;
end;</pstext>
    </ps>
