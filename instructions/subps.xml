  <ps_section howmany="1">
    <ps name="A64.dpreg.dp_2src.SUBPS_64S_dp_2src" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">var operand1 : bits(64) = if n == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
var operand2 : bits(64) = if m == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(m);
operand1 = SignExtend{64}(operand1[55:0]);
operand2 = NOT(SignExtend{64}(operand2[55:0]));
var result : bits(64);
var nzcv : bits(4);

(result, nzcv) = <a link="func_AddWithCarry_4" file="shared_pseudocode.xml">AddWithCarry</a>{64}(operand1, operand2, '1');

<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = result;
PSTATE.[N,Z,C,V] = nzcv;</pstext>
    </ps>
