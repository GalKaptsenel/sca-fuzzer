  <ps_section howmany="1">
    <ps name="A64.sve.sve_intx_narrowing.sve_intx_multi_shift_narrow.sqrshrn_z_mz2_b" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV (2 * esize);
var result : bits(VL);

for e = 0 to elements-1 do
    for i = 0 to 1 do
        let operand : bits(VL) = Z{}(n+i);
        let element : bits(2 * esize) = operand[e*:(2 * esize)];
        let res : integer = (SInt(element) + (1 &lt;&lt; (shift-1))) &gt;&gt; shift;
        result[(2*e + i)*:esize] = <a link="func_SignedSat_2" file="shared_pseudocode.xml">SignedSat</a>{esize}(res);
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
