      <ps_section howmany="1">
        <ps name="A64.sve.sve_perm_quads_a.sve_int_perm_dupq_i.dupq_z_zi_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SVE2p1) &amp;&amp; !IsFeatureImplemented(FEAT_SME2p1) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
if tsz == '0000' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let lsb : integer{} = LowestSetBit(tsz);
let esize : integer{} = 8 &lt;&lt; lsb;
let imm : bits(5) = i1::tsz;
let index : integer = UInt(imm[4:(lsb+1)]);
let n : integer = UInt(Zn);
let d : integer = UInt(Zd);</pstext>
