  <ps_section howmany="1">
    <ps name="A64.dpreg.dp_2src.SDIV_32_dp_2src" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">let operand1 : bits(datasize) = X{}(n);
let operand2 : bits(datasize) = X{}(m);
let dividend : integer = SInt(operand1);
let divisor : integer  = SInt(operand2);
var result : integer;
if divisor == 0 then
    result = 0;
elsif (dividend &lt; 0) == (divisor &lt; 0) then
    result = Abs(dividend) DIVRM Abs(divisor);    // same signs - positive result
else
    result = -(Abs(dividend) DIVRM Abs(divisor)); // different signs - negative result
end;
<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{datasize}(d) = result[datasize-1:0];</pstext>
    </ps>
