  <ps_section howmany="1">
    <ps name="A64.simd_dp.float2int.UCVTF_H32_float2int" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();

let fltsize : integer{} = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then 128 else decode_fltsize;

let intval : bits(intsize) = X{}(n);
let rounding : <a link="type_FPRounding" file="shared_pseudocode.xml">FPRounding</a>  = <a link="func_FPRoundingMode_1" file="shared_pseudocode.xml">FPRoundingMode</a>(FPCR());
let fracbits : integer = 0;
var fltval : bits(fltsize) = if <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR()) then V{fltsize}(d) else Zeros{fltsize};
fltval[0+:decode_fltsize] = <a link="func_FixedToFP_7" file="shared_pseudocode.xml">FixedToFP</a>{decode_fltsize, intsize}(intval, fracbits, unsigned,
                                                               FPCR(), rounding);

V{fltsize}(d) = fltval;</pstext>
    </ps>
