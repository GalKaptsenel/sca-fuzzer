  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_sve_2a.mortlach_multi2_z_z_shift_sm.urshl_mz_zzv_2x1" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
var results : array [[4]] of bits(VL);

for r = 0 to nreg-1 do
    let operand1 : bits(VL) = Z{}(dn+r);
    let operand2 : bits(VL) = Z{}(m);
    for e = 0 to elements-1 do
        let element : integer =  UInt(operand1[e*:esize]);
        var shift : integer = <a link="func_ShiftSat_2" file="shared_pseudocode.xml">ShiftSat</a>(SInt(operand2[e*:esize]), esize);
        var res : integer;
        if shift &gt;= 0 then
            res = element &lt;&lt; shift;
        else
            shift = -shift;
            res = (element + (1 &lt;&lt; (shift - 1))) &gt;&gt; shift;
        end;
        results[[r]][e*:esize] = res[esize-1:0];
    end;
end;

for r = 0 to nreg-1 do
    <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dn+r) = results[[r]];
end;</pstext>
    </ps>
