  <ps_section howmany="1">
    <ps name="A64.sve.sve_pred_count_a.sve_int_pcount_pred.lastp_r_p_p_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand : bits(PL) = P{}(n);
var index : integer = -1;

for e = elements-1 downto 0 do
    if (index == -1 &amp;&amp; <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) &amp;&amp;
          <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(operand, e, esize)) then
        index = e;
    end;
end;

<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = index[63:0];</pstext>
    </ps>
