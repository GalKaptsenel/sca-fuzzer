  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdsame2.FCADD_asimdsame2_C" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(datasize) = V{}(n);
let operand2 : bits(datasize) = V{}(m);
var result : bits(datasize);
var element1 : bits(esize);
var element3 : bits(esize);

for e = 0 to (elements DIV 2)-1 do
    case rot of
        when '0' =&gt;
            element1 = <a link="func_FPNeg_3" file="shared_pseudocode.xml">FPNeg</a>{esize}(operand2[(e*2+1)*:esize], FPCR());
            element3 = operand2[(e*2)*:esize];
        when '1' =&gt;
            element1 = operand2[(e*2+1)*:esize];
            element3 = <a link="func_FPNeg_3" file="shared_pseudocode.xml">FPNeg</a>{esize}(operand2[(e*2)*:esize], FPCR());
    end;
    result[(e*2)*:esize] = <a link="func_FPAdd_4" file="shared_pseudocode.xml">FPAdd</a>{esize}(operand1[(e*2)*:esize], element1, FPCR());
    result[(e*2+1)*:esize] = <a link="func_FPAdd_4" file="shared_pseudocode.xml">FPAdd</a>{esize}(operand1[(e*2+1)*:esize], element3, FPCR());
end;

V{datasize}(d) = result;</pstext>
    </ps>
