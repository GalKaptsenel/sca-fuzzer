      <ps_section howmany="1">
        <ps name="A64.control.syspairinstrs.SYSP_CR_syspairinstrs" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SYSINSTR128) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if Rt[0] == '1' &amp;&amp; Rt != '11111' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let t : integer       = UInt(Rt);
let t2 : integer      = if t == 31 then 31 else t + 1;
let sys_L : bits(1)   = L;
let sys_op0 : bits(2) = '01';
let sys_op1 : bits(3) = op1;
let sys_op2 : bits(3) = op2;
let sys_crn : bits(4) = CRn;
let sys_crm : bits(4) = CRm;</pstext>
