        let preferred_exception_return : bits(64) = ThisInstrAddr{}();
        let vect_offset : integer = 0x0;
        AArch64_TakeException(<a link="global_EL2" file="shared_pseudocode.xml">EL2</a>, except, preferred_exception_return, vect_offset);
    end;
end;

