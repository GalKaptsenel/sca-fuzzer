let esize : integer{} = 8 &lt;&lt; UInt(size);
let g : integer = UInt(Pg);
let dn : integer = UInt(Rdn);
let m : integer = UInt(Zm);
let csize : integer{} = if esize &lt; 64 then 32 else 64;
let isBefore : boolean = TRUE;</pstext>
