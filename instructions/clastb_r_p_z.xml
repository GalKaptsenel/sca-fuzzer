  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_pred.sve_int_perm_clast_rz.clastb_r_p_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand1 : bits(esize) = X{}(dn);
let operand2 : bits(VL) = Z{}(m);
var result : bits(csize);
var last : integer = <a link="func_LastActiveElement_3" file="shared_pseudocode.xml">LastActiveElement</a>{PL}(mask, esize);

if last &lt; 0 then
    result = ZeroExtend{csize}(operand1);
else
    if !isBefore then
        last = last + 1;
        if last &gt;= elements then last = 0; end;
    end;
    result = ZeroExtend{csize}(operand2[last*:esize]);

end;
<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{csize}(dn) = result;</pstext>
    </ps>
