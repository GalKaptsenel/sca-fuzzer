  <ps_section howmany="1">
    <ps name="A64.simd_dp.asisdelem.SQRDMULH_asisdelem_R" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand1 : bits(datasize) = V{}(n);
let operand2 : bits(idxdsize) = V{}(m);
var result : bits(datasize);
var element1 : integer;
var element2 : integer;
var product : integer;
var sat : boolean;

element2 = SInt(operand2[index*:esize]);
for e = 0 to elements-1 do
    element1 = SInt(operand1[e*:esize]);
    product = 2 * element1 * element2;
    product = <a link="func_RShr_3" file="shared_pseudocode.xml">RShr</a>(product, esize, round);
    // The following only saturates if element1 and element2 equal -(2^(esize-1))
    (result[e*:esize], sat) = <a link="func_SignedSatQ_2" file="shared_pseudocode.xml">SignedSatQ</a>{esize}(product);
    if sat then FPSR().QC = '1'; end;
end;

V{datasize}(d) = result;</pstext>
    </ps>
  </ps_section>
