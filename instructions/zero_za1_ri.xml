  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multizero.mortlach_multi_zero.zero_za1_ri_2" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEAndZAEnabled();
let VL : integer{} = CurrentVL();
let vectors : integer = VL DIV 8;
let vstride : integer = vectors DIV ngrp;
let vbase : bits(32) = X{}(v);
var vec : integer = (UInt(vbase) + offset) MOD vstride;
for r = 0 to ngrp-1 do
    <a link="accessor_ZAvector_2" file="shared_pseudocode.xml">ZAvector</a>{VL}(vec) = Zeros{VL};
    vec = vec + vstride;
end;</pstext>
    </ps>
