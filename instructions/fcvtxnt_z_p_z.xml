  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_fcvt2.sve_fp_fcvt2.fcvtxnt_z_p_z_d2s" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let halfesize : integer{} = esize DIV 2;
let mask : bits(PL) = P{}(g);
let operand : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
var result : bits(VL) = Z{}(d);

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        let element : bits(esize) = operand[e*:esize];
        result[(2*e + 1)*:halfesize] = <a link="func_FPConvertSVE_5" file="shared_pseudocode.xml">FPConvertSVE</a>{halfesize, esize}(element, FPCR(),
                                                                      <a link="enum_FPRounding_ODD" file="shared_pseudocode.xml">FPRounding_ODD</a>);

    elsif !merging then
        result[(2*e + 1)*:halfesize] = Zeros{halfesize};

    end;
end;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
