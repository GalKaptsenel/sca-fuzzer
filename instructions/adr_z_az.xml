  <ps_section howmany="1">
    <ps name="A64.sve.sve_int_adr.sve_int_bin_cons_misc_0_a.adr_z_az_sd_same_scaled" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckNonStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let base : bits(VL) = Z{}(n);
let offs : bits(VL) = Z{}(m);
var result : bits(VL);

for e = 0 to elements-1 do
    let addr : bits(esize) = base[e*:esize];
    let offselt : bits(osize) = offs[e*:esize][osize-1:0];
    let offset : integer = if unsigned then UInt(offselt) else SInt(offselt);
    result[e*:esize] = addr + (offset * mbytes);
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
