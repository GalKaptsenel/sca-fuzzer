  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdmisc.FRINT64X_asimdmisc_R" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize) = V{}(n);
var result : bits(datasize);
let rounding : <a link="type_FPRounding" file="shared_pseudocode.xml">FPRounding</a> = <a link="func_FPRoundingMode_1" file="shared_pseudocode.xml">FPRoundingMode</a>(FPCR());
var element : bits(esize);

for e = 0 to elements-1 do
    element = operand[e*:esize];
    result[e*:esize] = <a link="func_FPRoundIntN_5" file="shared_pseudocode.xml">FPRoundIntN</a>{esize}(element, FPCR(), rounding, intsize);
end;

V{datasize}(d) = result;</pstext>
    </ps>
