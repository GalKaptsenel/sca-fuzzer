      <ps_section howmany="1">
        <ps name="A64.simd_dp.asisdone.DUP_asisdone_only" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_AdvSIMD) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if imm5 == 'x0000' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let size : integer{} = LowestSetBitNZ(imm5[3:0]);

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let index : integer = UInt(imm5[4:size+1]);
let idxdsize : integer{} = 64 &lt;&lt; UInt(imm5[4]);
let esize : integer{} = 8 &lt;&lt; size;
let datasize : integer{} = esize;
let elements : integer = 1;</pstext>
        </ps>
      </ps_section>
