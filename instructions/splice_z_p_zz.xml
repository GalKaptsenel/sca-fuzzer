  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_pred.sve_intx_perm_splice.splice_z_p_zz_con" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(v);
let operand1 : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(s1) else Zeros{VL};
let operand2 : bits(VL) = Z{}(s2);
var result : bits(VL);
var x : integer = 0;
var active : boolean = FALSE;
let lastnum : integer = <a link="func_LastActiveElement_3" file="shared_pseudocode.xml">LastActiveElement</a>{PL}(mask, esize);

if lastnum &gt;= 0 then
    for e = 0 to lastnum do
        active = active || <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize);
        if active then
            result[x*:esize] = operand1[e*:esize];
            x = x + 1;
        end;
    end;
end;

let nelements : integer = (elements - x) - 1;
for e = 0 to nelements do
    result[x*:esize] = operand2[e*:esize];
    x = x + 1;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(dst) = result;</pstext>
    </ps>
