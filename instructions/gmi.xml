    <ps name="A64.dpreg.dp_2src.GMI_64G_dp_2src" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">let address : bits(64) = if n == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
var mask : bits(64) = X{}(m);
let tag : bits(4) = <a link="func_AArch64_AllocationTagFromAddress_1" file="shared_pseudocode.xml">AArch64_AllocationTagFromAddress</a>(address);

mask[UInt(tag)] = '1';
<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = mask;</pstext>
