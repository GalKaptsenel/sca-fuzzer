    <ps name="A64.sve.sve_fp_unary_unpred.sve_fp8_fcvt_wide.bf1cvt_z_z8_b2bf" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckFPMREnabled();
if IsFeatureImplemented(FEAT_SME2) then CheckSVEEnabled(); else CheckNonStreamingSVEEnabled(); end;
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand : bits(VL) = Z{}(n);
var result : bits(VL);

for e = 0 to elements-1 do
    let element : bits(esize) = operand[e*:esize];
    let res : bits(d_esize) = <a link="func_FP8ConvertBF_4" file="shared_pseudocode.xml">FP8ConvertBF</a>(element[s_esize-1:0], issrc2, FPCR(), FPMR());
    result[e*:esize] = ZeroExtend{esize}(res);
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
