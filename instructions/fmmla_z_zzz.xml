  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_fmmla_nw.sve_fp_fmmla_nw.fmmla_z_zzz_h" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckNonStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
if VL &lt; esize * 4 then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let segments : integer = VL DIV (4 * esize);
let operand1 : bits(VL) = Z{}(n);
let operand2 : bits(VL) = Z{}(m);
let operand3 : bits(VL) = Z{}(da);
var result : bits(VL) = Zeros{};
var op1, op2 : bits(4*esize);
var res, addend : bits(4*esize);

for s = 0 to segments-1 do
    op1    = operand1[s*:(4*esize)];
    op2    = operand2[s*:(4*esize)];
    addend = operand3[s*:(4*esize)];
    res    = FPMatMulAdd{4*esize}(addend, op1, op2, esize, FPCR());
    result[s*:(4*esize)] = res;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(da) = result;</pstext>
    </ps>
