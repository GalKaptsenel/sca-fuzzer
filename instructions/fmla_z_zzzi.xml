  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_fma_by_indexed_elem.sve_fp_fma_by_indexed_elem.fmla_z_zzzi_h" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let eltspersegment : integer = 128 DIV esize;
let op1 : bits(VL) = Z{}(n);
let op2 : bits(VL) = Z{}(m);
var result : bits(VL) = Z{}(da);

for e = 0 to elements-1 do
    let segmentbase : integer = e - (e MOD eltspersegment);
    let s : integer = segmentbase + index;
    let elem2 : bits(esize) = op2[s*:esize];
    let elem1 : bits(esize) = (if op1_neg then <a link="func_FPNeg_3" file="shared_pseudocode.xml">FPNeg</a>{esize}(op1[e*:esize], FPCR())
                                  else op1[e*:esize]);
    let elem3 : bits(esize) = (if op3_neg then <a link="func_FPNeg_3" file="shared_pseudocode.xml">FPNeg</a>{esize}(result[e*:esize], FPCR())
                                  else result[e*:esize]);
    result[e*:esize] = <a link="func_FPMulAdd_5" file="shared_pseudocode.xml">FPMulAdd</a>{esize}(elem3, elem1, elem2, FPCR());

end;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(da) = result;</pstext>
    </ps>
