      <ps_section howmany="1">
        <ps name="A64.control.hints.PACIA1716_HI_hints" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_PAuth) then EndOfDecode(<a link="enum_Decode_NOP" file="shared_pseudocode.xml">Decode_NOP</a>); end;
var d : integer;
var n : integer;
var source_is_sp : boolean = FALSE;
var pacia1716 : boolean = FALSE;

case CRm::op2 of
    when '0011 000' =&gt; // PACIAZ
        d = 30;
        n = 31;
    when '0011 001' =&gt; // PACIASP
        d = 30;
        source_is_sp = TRUE;
        if IsFeatureImplemented(FEAT_BTI) then
            // Check for branch target compatibility between PSTATE.BTYPE
            // and implicit branch target of PACIASP instruction.
            let pacinst : <a link="type_PACInstType" file="shared_pseudocode.xml">PACInstType</a> = <a link="enum_PACIxSP" file="shared_pseudocode.xml">PACIxSP</a>;
            SetBTypeCompatible(<a link="func_BTypeCompatible_PAC_1" file="shared_pseudocode.xml">BTypeCompatible_PAC</a>(pacinst));
        end;
    when '0001 000' =&gt; // PACIA1716
        d = 17;
        n = 16;
        pacia1716 = TRUE;
end;</pstext>
