    else
        <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = <a link="func_AddPACIA_2" file="shared_pseudocode.xml">AddPACIA</a>(<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d), <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}());
    end;
else
    if IsFeatureImplemented(FEAT_PAuth_LR) &amp;&amp; PSTATE.PACM == '1' &amp;&amp; pacia1716 then
        <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = <a link="func_AddPACIA2_3" file="shared_pseudocode.xml">AddPACIA2</a>(<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d), <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n), <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(15));
    else
