  <ps_section howmany="1">
    <ps name="A64.sve.sve_fp_unary_unpred.sve_fp_ucvtf_wide.ucvtflt_z_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand : bits(VL) = Z{}(n);
var result : bits(VL);

for e = 0 to elements-1 do
    let element : bits(esize DIV 2) = operand[(2*e + 1)*:(esize DIV 2)];
    result[e*:esize] = <a link="func_FixedToFP_7" file="shared_pseudocode.xml">FixedToFP</a>{esize, esize DIV 2}(element, 0, unsigned, FPCR(), rounding);
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
