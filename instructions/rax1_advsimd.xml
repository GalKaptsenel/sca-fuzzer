  <ps_section howmany="1">
    <ps name="A64.simd_dp.cryptosha512_3.RAX1_VVV2_cryptosha512_3" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

let Vm : bits(128) = V{}(m);
let Vn : bits(128) = V{}(n);
V{128}(d) = Vn XOR (ROL(Vm[127:64], 1)::ROL(Vm[63:0], 1));</pstext>
