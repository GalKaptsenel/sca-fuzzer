  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_quads_c.sve_int_perm_tbxquads.tbxq_z_zz_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let segments : integer = VL DIV 128;
let elements : integer = 128 DIV esize;
let operand1 : bits(VL) = Z{}(n);
let operand2 : bits(VL) = Z{}(m);
var result : bits(VL) = Z{}(d);

for s = 0 to segments-1 do
    for e = 0 to elements-1 do
        let idx : integer = UInt(operand2[(s * elements + e)*:esize]);
        if idx &lt; elements then
            result[(s * elements + e)*:esize] = operand1[(s * elements + idx)*:esize];
        end;
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
