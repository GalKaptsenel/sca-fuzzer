      <ps_section howmany="1">
        <ps name="A64.dpreg.dp_1src.REV32_64_dp_1src" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if opc == '11' &amp;&amp; sf == '0' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);
let datasize : integer{} = 32 &lt;&lt; UInt(sf);
let container_size : integer{} = 8 &lt;&lt; UInt(opc);</pstext>
