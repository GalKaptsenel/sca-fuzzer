  <ps_section howmany="1">
    <ps name="A64.ldst.loadlit.LDR_S_loadlit" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">let address : bits(64) = <a link="func_PC64_0" file="shared_pseudocode.xml">PC64</a>() + offset;
AArch64_CheckFPEnabled();
let privileged : boolean = PSTATE.EL != <a link="global_EL0" file="shared_pseudocode.xml">EL0</a>;
let accdesc : <a link="type_AccessDescriptor" file="shared_pseudocode.xml">AccessDescriptor</a> = CreateAccDescASIMD(MemOp_LOAD, nontemporal,
                                                       tagchecked, privileged);
let data : bits(size*8) = <a link="accessor_Mem_3" file="shared_pseudocode.xml">Mem</a>{size*8}(address, accdesc);
V{size*8}(t) = data;</pstext>
    </ps>
