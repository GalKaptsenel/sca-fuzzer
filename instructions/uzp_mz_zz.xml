  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_sve_3.mortlach_multi2_z_z_zip.uzp_mz_zz_2" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
if VL &lt; esize * 2 then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let pairs : integer = VL DIV (esize * 2);
var result0 : bits(VL);
var result1 : bits(VL);

for r = 0 to 1 do
    let base : integer = r * pairs;
    let operand : bits(VL) = if r == 0 then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(m);
    for p = 0 to pairs-1 do
        result0[(base+p)*:esize] = operand[(2*p+0)*:esize];
        result1[(base+p)*:esize] = operand[(2*p+1)*:esize];
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d+0) = result0;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d+1) = result1;</pstext>
    </ps>
