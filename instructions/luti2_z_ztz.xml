      <ps_section howmany="1">
        <ps name="A64.sme.mortlach_zt_expand_ctg.mortlach_expand_1dst.luti2_z_ztz_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SME2) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if size == '11' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8 &lt;&lt; UInt(size);
let isize : integer{} = 2;
let n : integer = UInt(Zn);
let d : integer = UInt(Zd);
let imm : integer = UInt(i4);
let nreg : integer{} = 1;</pstext>
