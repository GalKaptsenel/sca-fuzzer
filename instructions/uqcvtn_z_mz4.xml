  <ps_section howmany="1">
    <ps name="A64.sme.mortlach_multi_sve_4.mortlach_multi4_narrow_int_cvrt.uqcvtn_z_mz4_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV (4 * esize);
var result : bits(VL);

for e = 0 to elements-1 do
    for i = 0 to 3 do
        let operand : bits(VL) = Z{}(n+i);
        let element : integer = UInt(operand[e*:(4 * esize)]);
        result[(4*e + i)*:esize] = <a link="func_UnsignedSat_2" file="shared_pseudocode.xml">UnsignedSat</a>{esize}(element);
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
