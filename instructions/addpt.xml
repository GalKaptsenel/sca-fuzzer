  <ps_section howmany="1">
    <ps name="A64.dpreg.addsub_pt.ADDPT_64_addsub_pt" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">var result : bits(64);
let base : bits(64) = if n == 31 then <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() else <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(n);
let offset : bits(64) = LSL(<a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(m), shift);

result = base + offset;
result = <a link="func_PointerAddCheck_2" file="shared_pseudocode.xml">PointerAddCheck</a>(result, base);

if d == 31 then
    <a link="accessor_SP_1" file="shared_pseudocode.xml">SP</a>{64}() = result;
else
    <a link="accessor_X_2" file="shared_pseudocode.xml">X</a>{64}(d) = result;
end;</pstext>
