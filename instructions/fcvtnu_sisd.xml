  <ps_section howmany="1">
    <ps name="A64.simd_dp.float2int.FCVTNU_sisd_32H" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPEnabled();

var fltval : bits(fltsize);
var intval : bits(intsize);
let merge : boolean = <a link="func_IsMerging_1" file="shared_pseudocode.xml">IsMerging</a>(FPCR());
var result : bits(128) = if merge then V{128}(d) else Zeros{128};

fltval = V{fltsize}(n);
intval = <a link="func_FPToFixed_7" file="shared_pseudocode.xml">FPToFixed</a>{intsize, fltsize}(fltval, 0, TRUE, FPCR(), <a link="enum_FPRounding_TIEEVEN" file="shared_pseudocode.xml">FPRounding_TIEEVEN</a>);
result[0+:intsize] = intval;

V{128}(d) = result;</pstext>
    </ps>
