      <ps_section howmany="1">
        <ps name="A64.simd_dp.float2int.FCVTNU_sisd_32H" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FPRCVT) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let d : integer = UInt(Rd);
let n : integer = UInt(Rn);

let intsize : integer{} = 32 &lt;&lt; UInt(sf);
let fltsize : integer{} = 8 &lt;&lt; UInt(ftype XOR '10');</pstext>
