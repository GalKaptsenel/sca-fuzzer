  <ps_section howmany="1">
    <ps name="A64.sve.sve_intx_narrowing.sve_intx_extract_narrow.sqxtunb_z_zz_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand1 : bits(VL) = Z{}(n);
var result : bits(VL);
let halfesize : integer{} = esize DIV 2;

for e = 0 to elements-1 do
    let element1 : integer = SInt(operand1[e*:esize]);
    let res : bits(halfesize) = <a link="func_UnsignedSat_2" file="shared_pseudocode.xml">UnsignedSat</a>{halfesize}(element1);
    result[(2*e + 0)*:halfesize] = res;
    result[(2*e + 1)*:halfesize] = Zeros{halfesize};

end;
<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
