  <ps_section howmany="1">
    <ps name="A64.simd_dp.asimdall.SMINV_asimdall_only" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();
let operand : bits(datasize) = V{}(n);
var opelt : bits(esize) = operand[0+:esize];
var min : integer = if unsigned then UInt(opelt) else SInt(opelt);

for e = 1 to elements-1 do
    opelt = operand[e*:esize];
    let element : integer = if unsigned then UInt(opelt) else SInt(opelt);
    min = Min(min, element);
end;

V{esize}(d) = min[esize-1:0];</pstext>
    </ps>
