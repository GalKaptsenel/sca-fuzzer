  <ps_section howmany="1">
    <ps name="A64.sve.sve_int_pred_red.sve_int_movprfx_pred.movprfx_z_p_z_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let elements : integer = VL DIV esize;
let mask : bits(PL) = P{}(g);
let operand1 : bits(VL) = if <a link="func_AnyActiveElement_3" file="shared_pseudocode.xml">AnyActiveElement</a>{PL}(mask, esize) then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(n) else Zeros{VL};
let dest : bits(VL) = if merging then <a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) else Zeros{VL};
var result : bits(VL);

for e = 0 to elements-1 do
    if <a link="func_ActivePredicateElement_4" file="shared_pseudocode.xml">ActivePredicateElement</a>{PL}(mask, e, esize) then
        let element : bits(esize) = operand1[e*:esize];
        result[e*:esize] = element;
    else
        result[e*:esize] = dest[e*:esize];
    end;
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
