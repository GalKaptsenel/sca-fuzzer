  <ps_section howmany="1">
    <ps name="A64.simd_dp.cryptosha512_3.SM3PARTW2_VVV4_cryptosha512_3" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

let Vm : bits(128) = V{}(m);
let Vn : bits(128) = V{}(n);
let Vd : bits(128) = V{}(d);

var result : bits(128);
var tmp : bits(128);
var tmp2 : bits(32);

tmp[127:0] = (Vn XOR
              (ROL(Vm[127:96], 7) :: ROL(Vm[95:64], 7) :: ROL(Vm[63:32], 7) :: ROL(Vm[31:0], 7)));
result[127:0] = Vd[127:0] XOR tmp[127:0];
tmp2 = ROL(tmp[31:0], 15);
tmp2 = tmp2 XOR ROL(tmp2, 15) XOR ROL(tmp2, 23);
result[127:96] = result[127:96] XOR tmp2;
V{128}(d) = result;</pstext>
    </ps>
