  <ps_section howmany="1">
    <ps name="A64.simd_dp.crypto3_imm6.XAR_VVV2_crypto3_imm6" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">AArch64_CheckFPAdvSIMDEnabled();

let Vm : bits(128) = V{}(m);
let Vn : bits(128) = V{}(n);
let tmp : bits(128) = Vn XOR Vm;
V{128}(d) = ROR(tmp[127:64], UInt(imm6))::ROR(tmp[63:0], UInt(imm6));</pstext>
