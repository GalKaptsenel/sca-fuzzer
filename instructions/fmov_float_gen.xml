      <ps_section howmany="1">
        <ps name="A64.simd_dp.float2int.FMOV_32H_float2int" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_FP) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if ftype == '10' &amp;&amp; opcode[2:1]::rmode != '11 01' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
if ftype == '11' &amp;&amp; !IsFeatureImplemented(FEAT_FP16) then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;

let d : integer{} = UInt(Rd);
let n : integer{} = UInt(Rn);

let intsize : integer{} = 32 &lt;&lt; UInt(sf);
let fltsize : integer{} = if ftype == '10' then 64 else (8 &lt;&lt; UInt(ftype XOR '10'));
let part : integer = UInt(rmode[0]);
var op : <a link="type_FPConvOp" file="shared_pseudocode.xml">FPConvOp</a>;

case opcode[2:1]::rmode of
    when '11 00' =&gt;        // FMOV
        if fltsize != 16 &amp;&amp; fltsize != intsize then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
        op = if opcode[0] == '1' then <a link="enum_FPConvOp_MOV_ItoF" file="shared_pseudocode.xml">FPConvOp_MOV_ItoF</a> else <a link="enum_FPConvOp_MOV_FtoI" file="shared_pseudocode.xml">FPConvOp_MOV_FtoI</a>;
    when '11 01' =&gt;        // FMOV D[1]
        if intsize != 64 || ftype != '10' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
        op = if opcode[0] == '1' then <a link="enum_FPConvOp_MOV_ItoF" file="shared_pseudocode.xml">FPConvOp_MOV_ItoF</a> else <a link="enum_FPConvOp_MOV_FtoI" file="shared_pseudocode.xml">FPConvOp_MOV_FtoI</a>;
    otherwise =&gt;
        unreachable;
end;</pstext>
        </ps>
