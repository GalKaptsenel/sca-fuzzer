  <ps_section howmany="1">
    <ps name="A64.sve.sve_perm_predicates.sve_int_perm_bin_perm_pp.zip2_p_pp_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckSVEEnabled();
let VL : integer{} = CurrentVL();
let PL : integer{} = VL DIV 8;
let pairs : integer = VL DIV (esize * 2);
let operand1 : bits(PL) = P{}(n);
let operand2 : bits(PL) = P{}(m);
var result : bits(PL);

let base : integer = part * pairs;
for p = 0 to pairs-1 do
    result[(2*p+0)*:(esize DIV 8)] = operand1[(base+p)*:(esize DIV 8)];
    result[(2*p+1)*:(esize DIV 8)] = operand2[(base+p)*:(esize DIV 8)];
end;

<a link="accessor_P_2" file="shared_pseudocode.xml">P</a>{PL}(d) = result;</pstext>
    </ps>
