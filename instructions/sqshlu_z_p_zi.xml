      <ps_section howmany="1">
        <ps name="A64.sve.sve_int_pred_shift.sve_int_bin_pred_shift_0.sqshlu_z_p_zi_" sections="1" secttype="noheading">
          <pstext mayhavelinks="1" section="Decode" rep_section="decode">if !IsFeatureImplemented(FEAT_SVE2) &amp;&amp; !IsFeatureImplemented(FEAT_SME) then
    EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>);
end;
let tsize : bits(4) = tszh::tszl;
if tsize == '0000' then EndOfDecode(<a link="enum_Decode_UNDEF" file="shared_pseudocode.xml">Decode_UNDEF</a>); end;
let esize : integer{} = 8 &lt;&lt; HighestSetBitNZ(tsize);
let g : integer = UInt(Pg);
let dn : integer = UInt(Zdn);
let shift : integer = UInt(tsize::imm3) - esize;</pstext>
        </ps>
