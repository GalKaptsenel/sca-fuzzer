  <ps_section howmany="1">
    <ps name="A64.sve.sve_int_unpred_misc.sve_int_bin_cons_misc_0_b.ftssel_z_zz_" sections="1" secttype="Operation">
      <pstext mayhavelinks="1" section="Execute" rep_section="execute">CheckNonStreamingSVEEnabled();
let VL : integer{} = CurrentVL();
let elements : integer = VL DIV esize;
let operand1 : bits(VL) = Z{}(n);
let operand2 : bits(VL) = Z{}(m);
var result : bits(VL);

for e = 0 to elements-1 do
    let element1 : bits(esize) = operand1[e*:esize];
    let element2 : bits(esize) = operand2[e*:esize];
    result[e*:esize] = <a link="func_FPTrigSSel_3" file="shared_pseudocode.xml">FPTrigSSel</a>{esize}(element1, element2);
end;

<a link="accessor_Z_2" file="shared_pseudocode.xml">Z</a>{VL}(d) = result;</pstext>
    </ps>
